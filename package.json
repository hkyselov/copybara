{
  "name": "copybara",
  "productName": "Copybara",
  "version": "1.0.1",
  "description": "Copybara Clipboard Manager",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "mac": "npm run make -- --arch=universal --platform=darwin",
    "mas": "npm run make -- --arch=universal --platform=mas",
    "mas-release": "BUILD_TYPE=release npm run mas",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\""
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.5.0",
    "@electron-forge/maker-deb": "^7.5.0",
    "@electron-forge/maker-dmg": "^7.5.0",
    "@electron-forge/maker-pkg": "^7.5.0",
    "@electron-forge/maker-rpm": "^7.5.0",
    "@electron-forge/maker-squirrel": "^7.5.0",
    "@electron-forge/maker-zip": "^7.5.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.5.0",
    "@electron-forge/plugin-fuses": "^7.5.0",
    "@electron/fuses": "^1.8.0",
    "@electron/osx-sign": "1.3.0",
    "electron": "33.0.2"
  },
  "keywords": [],
  "author": {
    "name": "Hennadiy Kyselov",
    "email": "kyseliov@gmail.com"
  },
  "license": "MIT",
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^10.0.0"
  }
}
